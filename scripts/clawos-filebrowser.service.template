[Unit]
Description=ClawOS FileBrowser Service
After=network.target

[Service]
Type=simple
WorkingDirectory=__PROJECT_DIR__/filebrowser
ExecStart=/usr/local/bin/filebrowser -d ./filebrowser.db -a '127.0.0.1' -p 18790
Restart=always
RestartSec=3
TimeoutStopSec=8
KillSignal=SIGTERM

[Install]
WantedBy=default.target
