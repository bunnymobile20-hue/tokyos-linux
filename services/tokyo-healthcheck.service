[Unit]
Description=Tokyo OS Health Check Runner
After=network.target

[Service]
Type=oneshot
User=tokio
Group=tokio
WorkingDirectory=/home/tokio/TokiOS
ExecStart=/home/tokio/TokiOS/dashboard/venv/bin/python /home/tokio/TokiOS/tools/health_check/runner.py
StandardOutput=append:/home/tokio/TokiOS/logs/healthcheck.log
StandardError=append:/home/tokio/TokiOS/logs/healthcheck_errors.log
