#!/bin/sh
# tokyos-init — Configuração inicial do TokyOS Linux
# Executa no primeiro boot para preparar partição de dados e tokens
# Instalado como tokyos-firstboot.service (one-shot)

set -e

PATH=/usr/local/bin:/usr/bin:/bin
export PATH

PROGNAME="$(basename "$0")"
LOGFILE=/var/log/tokyos-firstboot.log
CONFIG_DIR=/etc/tokyos
DATA_DIR=/mnt/data

log() {
    echo "[$(date +%H:%M:%S)] $PROGNAME: $*" | tee -a "$LOGFILE"
}

# ============================================================
# Prepara partição de dados persistente
# ============================================================
setup_data() {
    log "Preparando partição de dados..."

    DATA_DEV=""
    for dev in /dev/sd* /dev/nvme* /dev/mmcblk*; do
        [ -b "$dev" ] || continue
        label=$(blkid -s LABEL -o value "$dev" 2>/dev/null || echo "")
        if [ "$label" = "TOKYOS-DATA" ]; then
            DATA_DEV="$dev"
            break
        fi
    done

    if [ -n "$DATA_DEV" ]; then
        mount "$DATA_DEV" "$DATA_DIR" 2>/dev/null || {
            log "AVISO: falha ao montar $DATA_DEV, formatando..."
            mkfs.ext4 -L TOKYOS-DATA "$DATA_DEV"
            mount "$DATA_DEV" "$DATA_DIR"
        }
        log "Dados montados de $DATA_DEV"
    else
        log "Nenhuma partição TOKYOS-DATA encontrada. Dados em tmpfs."
        mount -t tmpfs -o size=512M tmpfs "$DATA_DIR"
    fi

    mkdir -p "$DATA_DIR"/{var/log,opt/tokyos/data,etc/tokyos}
    ln -sfn "$DATA_DIR/var/log" /var/log 2>/dev/null || true
    ln -sfn "$DATA_DIR/etc/tokyos" /etc/tokyos 2>/dev/null || true
}

# ============================================================
# Gera AUTHTOKEN para API
# ============================================================
setup_auth() {
    TOKEN_FILE="$DATA_DIR/opt/tokyos/AUTHTOKEN"
    if [ ! -f "$TOKEN_FILE" ]; then
        MACHINE_ID=$(cat /etc/machine-id 2>/dev/null || echo "tokyos-$(uname -n)-$(date +%Y%m)")
        echo -n "$MACHINE_ID" | sha256sum | cut -d' ' -f1 > "$TOKEN_FILE"
        chmod 600 "$TOKEN_FILE"
        log "AUTHTOKEN gerado"
    fi
    export AUTHTOKEN=$(cat "$TOKEN_FILE")
    log "AUTHTOKEN: ${AUTHTOKEN:0:8}..."
}

# ============================================================
# Configura tokyos.conf padrão
# ============================================================
setup_config() {
    if [ ! -f "$CONFIG_DIR/tokyos.conf" ]; then
        mkdir -p "$CONFIG_DIR"
        cat > "$CONFIG_DIR/tokyos.conf" << 'CONFEOF'
# TokyOS Config
DASHBOARD_URL=http://127.0.0.1:3001
DISPLAY_SERVER=auto
UPDATE_CHANNEL=stable
CONFEOF
        log "tokyos.conf criado"
    fi
}

# ============================================================
# Atualiza GRUB se estiver em disco (não live)
# ============================================================
setup_grub() {
    if [ -d /sys/firmware/efi ] && [ -f /boot/grub/grub.cfg ]; then
        update-grub 2>/dev/null || true
        log "GRUB atualizado"
    fi
}

# ============================================================
# MAIN
# ============================================================
log "=== TokyOS first-boot init ==="

setup_data
setup_auth
setup_config

# Aplica config GNOME no primeiro boot
if [ -f /opt/tokyos/scripts/setup-gnome.sh ]; then
    /opt/tokyos/scripts/setup-gnome.sh
    log "Configuração GNOME aplicada"
fi

# Só roda GRUB update se não for live CD
if ! grep -q "boot=live" /proc/cmdline 2>/dev/null; then
    setup_grub
fi

log "=== TokyOS first-boot concluido ==="
